# Django Settings
DEBUG=False
SECRET_KEY=your-secure-secret-key-here
ALLOWED_HOSTS=launchpadglobal.com.np,www.launchpadglobal.com.np

# Database Configuration (PostgreSQL)
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password
DB_HOST=your-db-host
DB_PORT=5432

# CORS Configuration (Frontend Origins)
CORS_ALLOWED_ORIGINS=https://launchpadglobal.com.np,https://www.launchpadglobal.com.np

# CSRF Trusted Origins (Must match CORS origins for cross-origin POST/PUT/DELETE)
CSRF_TRUSTED_ORIGINS=https://launchpadglobal.com.np,https://www.launchpadglobal.com.np

# Django Logging Level
DJANGO_LOG_LEVEL=INFO

# Static and Media URLs
STATIC_URL=/static/
MEDIA_URL=/media/

